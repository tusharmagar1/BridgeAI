# BridgeAI Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development
# Production Frontend URL (Required in production)
FRONTEND_URL=https://your-frontend-domain.com

# GroqCloud API (Required)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# MySQL Database (Required)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bridgeai
DB_USER=root
DB_PASSWORD=your_database_password_here

# Redis Cache & Rate Limiting (Required)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting Settings
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ElevenLabs Text-to-Speech (Optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Cloud Text-to-Speech (Optional)
# Set the path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=your_google_credentials_path_here
